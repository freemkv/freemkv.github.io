---
// Custom override of Starlight's SiteTitle. Renders the default brand
// (logo + site name, linking home) and, next to it, a persistent "Download"
// CTA so docs pages have a direct path to /download/ — otherwise a reader in
// the docs has to navigate back to the landing page to grab a binary. Lives in
// the title slot (left of the header) so it stays visible at every width
// instead of folding into the mobile hamburger like the social icons do.
import Default from '@astrojs/starlight/components/SiteTitle.astro';
---

<Default><slot /></Default>
<a class="header-download" href="/download/">Download</a>

<style>
  .header-download {
    margin-inline-start: 1rem;
    padding: 0.3em 0.85em;
    border-radius: 0.4rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    line-height: 1.4;
    white-space: nowrap;
    text-decoration: none;
  }
  .header-download:hover {
    background: var(--sl-color-accent-high);
  }
  /* Very narrow viewports: tighten so it doesn't crowd the brand. */
  @media (max-width: 30em) {
    .header-download {
      margin-inline-start: 0.5rem;
      padding: 0.3em 0.6em;
    }
  }
</style>
