---
// Custom override of Starlight's SocialIcons. Renders the configured social
// links (the GitHub icon) and, alongside them, a live GitHub star count that
// links to the main freemkv repository and opens in a new tab.
//
// The star count is fetched client-side from the GitHub REST API and cached in
// localStorage with a 1-hour TTL to stay well under the unauthenticated rate
// limit (~60 req/hr/IP). No token is embedded. On fetch failure (or before the
// first successful load) the link renders as just the star icon with no number.
import Default from '@astrojs/starlight/components/SocialIcons.astro';

// The repo the site already links to (see astro.config.mjs `social` + docs).
const GH_REPO = 'freemkv/freemkv';
---

<Default><slot /></Default>

<a
  class="freemkv-discord sl-flex"
  href="https://discord.gg/kDh5esedcg"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Discord"
>
  <svg class="freemkv-discord__logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.211.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.956-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.956 2.42-2.157 2.42zm7.975 0c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.946 2.42-2.157 2.42z"/></svg>
  <span class="freemkv-discord__label">Discord</span>
</a>

<a
  class="freemkv-gh-stars sl-flex"
  href={`https://github.com/${GH_REPO}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="GitHub stars"
  data-gh-repo={GH_REPO}
>
  <span class="freemkv-gh-stars__count"><span data-gh-stars hidden></span>★</span>
  <span class="freemkv-gh-stars__label">GitHub</span>
</a>

<script>
  (() => {
    const el = document.querySelector<HTMLAnchorElement>('a.freemkv-gh-stars');
    if (!el) return;
    const repo = el.dataset.ghRepo;
    if (!repo) return;

    const countEl = el.querySelector<HTMLElement>('[data-gh-stars]');
    if (!countEl) return;

    const CACHE_KEY = `freemkv:gh-stars:${repo}`;
    const TTL_MS = 60 * 60 * 1000; // 1 hour

    // 1234 -> "1.2k", 12345 -> "12k", 999 -> "999".
    const format = (n: number): string => {
      if (!Number.isFinite(n) || n < 0) return '';
      if (n < 1000) return String(n);
      const k = n / 1000;
      const s = k < 10 ? k.toFixed(1) : Math.round(k).toString();
      return s.replace(/\.0$/, '') + 'k';
    };

    const show = (n: number) => {
      const text = format(n);
      if (!text) return;
      countEl.textContent = text;
      countEl.hidden = false;
      el.setAttribute('aria-label', `GitHub stars: ${n.toLocaleString()}`);
    };

    // Serve cached value immediately if still fresh.
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (raw) {
        const cached = JSON.parse(raw) as { count: number; ts: number };
        if (cached && typeof cached.count === 'number') {
          show(cached.count);
          if (Date.now() - cached.ts < TTL_MS) return; // still fresh, skip fetch
        }
      }
    } catch {
      /* ignore malformed cache */
    }

    fetch(`https://api.github.com/repos/${repo}`, {
      headers: { Accept: 'application/vnd.github+json' },
    })
      .then((r) => (r.ok ? r.json() : Promise.reject(new Error(`HTTP ${r.status}`))))
      .then((data: { stargazers_count?: number }) => {
        const count = data?.stargazers_count;
        if (typeof count !== 'number') return;
        show(count);
        try {
          localStorage.setItem(CACHE_KEY, JSON.stringify({ count, ts: Date.now() }));
        } catch {
          /* localStorage unavailable; non-fatal */
        }
      })
      .catch(() => {
        /* Leave the link as just the star icon; never render NaN. */
      });
  })();
</script>

<style>
  a.freemkv-gh-stars {
    align-items: center;
    gap: 0.35em;
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
    font-size: var(--sl-text-sm);
    font-variant-numeric: tabular-nums;
    text-decoration: none;
  }
  a.freemkv-gh-stars:hover {
    color: var(--sl-color-white);
  }
  .freemkv-gh-stars__count {
    line-height: 1;
    white-space: nowrap;
  }
  .freemkv-gh-stars__label {
    line-height: 1;
  }
  a.freemkv-discord {
    align-items: center;
    gap: 0.4em;
    color: var(--sl-color-text-accent);
    padding: 0.5em;
    margin: -0.5em;
    font-size: var(--sl-text-sm);
    text-decoration: none;
  }
  a.freemkv-discord:hover {
    color: var(--sl-color-white);
  }
  .freemkv-discord__logo {
    width: 1.25em;
    height: 1.25em;
  }
  /* Mobile / narrow viewports: drop the text labels to save space —
     keep just the star count (17★) and the Discord logo. */
  @media (max-width: 50em) {
    .freemkv-gh-stars__label,
    .freemkv-discord__label {
      display: none;
    }
  }
</style>
