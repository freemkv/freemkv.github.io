---
// Standalone product landing page for freemkv.org.
// This page owns the "/" route directly (NOT part of the Starlight docs
// collection) so it has full design freedom with none of the docs
// sidebar / TOC / breadcrumb chrome. The docs live under /overview/ etc.
const title = 'freemkv: a composable pipeline for optical-disc video';
const description =
  'AGPL-3.0 Rust toolchain built on one elegant idea: every input and every output is a scheme:// URL you compose — freemkv <source> <dest>. Rip, remux, demux, index, and stream DVD, Blu-ray, and 4K UHD, with AACS/CSS decryption and multi-pass bad-sector recovery built into the pipe.';
const download = '/download/';
const github = 'https://github.com/freemkv';
const docs = '/overview/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://freemkv.org/freemkv-icon.svg" />
    <meta property="og:url" content="https://freemkv.org/" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://freemkv.org/freemkv-icon.svg" />
  </head>
  <body>
    <!-- ============ STICKY NAV ============ -->
    <header class="nav">
      <div class="nav-inner">
        <a class="brand" href="/">
          <img src="/freemkv-icon.svg" alt="" width="32" height="32" />
          <span>freemkv</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href={docs}>Docs</a>
          <a href={download}>Download</a>
          <a
            class="nav-discord"
            href="https://discord.gg/kDh5esedcg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Discord"
          >
            <svg class="nav-discord-logo" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.211.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.956-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.956 2.42-2.157 2.42zm7.975 0c-1.183 0-2.157-1.086-2.157-2.42 0-1.333.955-2.42 2.157-2.42 1.21 0 2.176 1.096 2.157 2.42 0 1.334-.946 2.42-2.157 2.42z"/></svg>
          </a>
          <a
            class="gh-stars"
            href="https://github.com/freemkv/freemkv"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub stars"
            data-gh-repo="freemkv/freemkv"
          >
            <span class="gh-stars-num"><span data-gh-stars hidden></span>★</span>
            <svg class="gh-stars-logo" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
          </a>
        </nav>
      </div>
    </header>

    <main>
      <!-- ============ HERO ============ -->
      <section class="hero">
        <div class="hero-inner">
          <img class="hero-logo" src="/freemkv-icon.svg" alt="freemkv" width="96" height="96" />
          <h1 class="hero-title">Own your movies, not just the discs.</h1>
          <p class="hero-tagline">
            The open-source 4K&nbsp;UHD, Blu-ray &amp; DVD ripper.
          </p>
          <div class="cta-row">
            <a class="btn btn-primary" href={download}>Download latest release</a>
            <a class="btn btn-secondary" href={docs}>Read the docs</a>
            <a class="btn btn-ghost" href={github}>View on GitHub</a>
          </div>
          <p class="hero-foot">Free &amp; open source · Linux, macOS &amp; Windows · Intel &amp; ARM</p>
        </div>
      </section>

      <!-- ============ FEATURE GRID ============ -->
      <section class="features">
        <div class="section-inner">
          <h2 class="section-title">One pipeline, built on one idea.</h2>
          <div class="grid">
            <article class="card">
              <h3>Bad-sector recovery</h3>
              <p>
                A tolerant <strong>sweep</strong> reads the whole disc and skips past
                unreadable sectors, then <strong>patch</strong> passes retry only the
                damage, multi-attempt, with per-sector timeouts and range bisection.
              </p>
            </article>
            <article class="card">
              <h3>DVD, Blu-ray &amp; 4K&nbsp;UHD → MKV</h3>
              <p>
                Mux every readable title to a standards-clean MKV: video, audio,
                subtitles, chapters. DVDs (CSS) work out of the box; Blu-ray and 4K&nbsp;UHD
                need <a href="/decryption-keys/">decryption keys</a>.
              </p>
            </article>
            <article class="card">
              <h3>Insert a disc, get an MKV</h3>
              <p>
                autorip is a service that auto-detects optical drives, runs the full
                sweep → patch → mux pipeline on disc insert, and exposes a resumable web
                UI for settings, progress, and history. Run it as a single binary or in a
                container.
              </p>
            </article>
            <article class="card">
              <h3>Open source, single binary</h3>
              <p>
                Pure Rust. Download a prebuilt binary for Linux, macOS, or Windows, or
                build from source. The whole toolchain is licensed
                <strong>AGPL-3.0</strong>: run it anywhere, audit it, build on it.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- ============ HOW IT WORKS ============ -->
      <section class="how">
        <div class="section-inner">
          <h2 class="section-title">How it works</h2>
          <p class="section-lead">
            Three composable stages: read everything the drive can recover, then chase
            the rest. <a href="/how-recovery-works/">See how recovery works →</a>
          </p>
          <div class="steps">
            <div class="step">
              <div class="step-num">1</div>
              <h3>Sweep</h3>
              <p>Read the whole disc sequentially. Skip ahead past bad sectors, mark them, never abort.</p>
            </div>
            <div class="step-arrow" aria-hidden="true">→</div>
            <div class="step">
              <div class="step-num">2</div>
              <h3>Patch</h3>
              <p>Come back for the bad ranges with targeted, multi-attempt retries and bisection.</p>
            </div>
            <div class="step-arrow" aria-hidden="true">→</div>
            <div class="step">
              <div class="step-num">3</div>
              <h3>Mux</h3>
              <p>Decrypt and mux the recovered image into a clean, fully-featured MKV.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ============ SHOWCASE / TERMINAL ============ -->
      <section class="showcase">
        <div class="section-inner">
          <h2 class="section-title section-title--rotate" aria-label="From disc to MKV.">
            <span class="rot rot-1" aria-hidden="true">From disc to MKV.</span>
            <span class="rot rot-2" aria-hidden="true">From ISO to MKV.</span>
            <span class="rot rot-3" aria-hidden="true">From MKV to M2TS.</span>
            <span class="rot rot-4" aria-hidden="true">From disc to ISO.</span>
          </h2>
          <p class="section-lead">
            freemkv composes a <em>source</em> and a <em>destination</em> URL, with no rigid
            subcommands. Read from a disc, ISO, or M2TS; write to MKV, ISO, M2TS, a network
            stream, or stdout.
          </p>
          <div class="terminal">
            <div class="terminal-bar" aria-hidden="true">
              <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
              <span class="terminal-title">freemkv</span>
            </div>
            <pre class="terminal-body"><code><span class="c"># Rip a disc straight to MKV — the main path (decrypt + mux)</span>
<span class="p">$</span> freemkv disc:// mkv://Movie.mkv

<span class="c"># Remux an existing ISO to MKV — no disc needed, same shape</span>
<span class="p">$</span> freemkv iso://Disc.iso mkv://Movie.mkv

<span class="c"># Index a disc image, or extract its elementary streams</span>
<span class="p">$</span> freemkv iso://Disc.iso fvi://Disc.fvi
<span class="p">$</span> freemkv iso://Disc.iso demux://tracks/

<span class="c"># Pipe decrypted output to another tool over stdout</span>
<span class="p">$</span> freemkv disc:// stdio:// | ffmpeg -i - …</code></pre>
          </div>

          <p class="showcase-sub">Or run the whole thing as a service: insert a disc, get an MKV:</p>
          <div class="terminal terminal-compact">
            <div class="terminal-bar" aria-hidden="true">
              <span class="dot dot-r"></span><span class="dot dot-y"></span><span class="dot dot-g"></span>
              <span class="terminal-title">autorip</span>
            </div>
            <pre class="terminal-body"><code><span class="c"># Run the autorip binary as a daemon, then open http://&lt;host&gt;:8080</span>
<span class="p">$</span> ./autorip</code></pre>
          </div>
          <p class="showcase-note">
            <code>disc://</code> defaults to the main title; run <code>freemkv info disc://</code>
            to list every title with durations, or add <code>-t N</code> to pick one. The same
            <code>--multipass</code> recovery and decryption apply to whichever source and sink
            you compose.
          </p>
          <p class="showcase-note">
            autorip runs on Linux, macOS, and Windows as a single binary (or a Linux container).
            <a href="/download/">Download autorip</a> · see the
            <a href="/autorip/">autorip docs</a> for setup and
            <a href="/decryption-keys/">decryption keys</a> for Blu-ray and 4K&nbsp;UHD.
          </p>
        </div>
      </section>

      <!-- ============ CTA BAND ============ -->
      <section class="cta-band">
        <div class="section-inner cta-band-inner">
          <h2>Get started</h2>
          <p>Grab a prebuilt binary and get started.</p>
          <div class="cta-row">
            <a class="btn btn-primary" href={download}>Download latest release</a>
            <a class="btn btn-secondary" href="/overview/">Read the docs</a>
          </div>
        </div>
      </section>
    </main>

    <!-- ============ FOOTER ============ -->
    <footer class="footer">
      <div class="section-inner footer-inner">
        <div class="footer-brand">
          <img src="/freemkv-icon.svg" alt="" width="28" height="28" />
          <span>freemkv</span>
        </div>
        <nav class="footer-links" aria-label="Footer">
          <a href={docs}>Docs</a>
          <a href={github}>GitHub</a>
          <a href="https://crates.io/crates/libfreemkv">crates.io</a>
          <a href="https://github.com/freemkv/autorip/pkgs/container/autorip">GHCR (autorip)</a>
          <a href="https://github.com/freemkv/freemkv/blob/main/LICENSE">License (AGPL-3.0)</a>
        </nav>
      </div>
      <p class="footer-copy">AGPL-3.0 · Recover 100% of readable data from any optical disc.</p>
    </footer>

    <style>
      :root {
        --teal: #0d9488;
        --teal-dark: #0f766e;
        --teal-darker: #115e59;
        --teal-tint: #f0fdfa;
        --ink: #0f172a;
        --slate: #475569;
        --muted: #64748b;
        --line: #e2e8f0;
        --bg: #ffffff;
        --bg-soft: #f8fafc;
        --radius: 14px;
        --maxw: 1080px;
        --font: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica,
          Arial, sans-serif;
        --mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
      }

      * { box-sizing: border-box; }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        font-family: var(--font);
        color: var(--ink);
        background: var(--bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: var(--teal-dark); text-decoration: none; }
      a:hover { color: var(--teal-darker); }

      code {
        font-family: var(--mono);
        font-size: 0.9em;
        background: var(--teal-tint);
        color: var(--teal-darker);
        padding: 0.1em 0.35em;
        border-radius: 5px;
      }

      .section-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 clamp(1rem, 4vw, 2rem);
      }

      .section-title {
        font-size: clamp(1.6rem, 4vw, 2.25rem);
        font-weight: 750;
        letter-spacing: -0.02em;
        margin: 0 0 0.5rem;
        text-align: center;
      }
      /* Rotating "From <source> to <sink>." — pure CSS, no reflow (all phrases
         stack in one max-content grid cell), one visible at a time over a 12s
         loop. Reduced-motion shows only the first phrase (see media query). */
      .section-title--rotate {
        display: grid;
        width: max-content;
        max-width: 100%;
        margin-inline: auto;
        justify-items: center;
      }
      .section-title--rotate .rot {
        grid-area: 1 / 1;
        opacity: 0;
        animation: title-rotate 12s infinite;
      }
      .section-title--rotate .rot-2 { animation-delay: 3s; }
      .section-title--rotate .rot-3 { animation-delay: 6s; }
      .section-title--rotate .rot-4 { animation-delay: 9s; }
      @keyframes title-rotate {
        0%   { opacity: 0; }
        3%   { opacity: 1; }
        22%  { opacity: 1; }
        25%  { opacity: 0; }
        100% { opacity: 0; }
      }
      .section-lead {
        text-align: center;
        color: var(--muted);
        max-width: 46ch;
        margin: 0 auto 2.5rem;
        font-size: clamp(1rem, 2.5vw, 1.1rem);
      }

      /* ---------- NAV ---------- */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: saturate(180%) blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .nav-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0.75rem clamp(1rem, 4vw, 2rem);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 750;
        font-size: 1.15rem;
        color: var(--ink);
        letter-spacing: -0.01em;
      }
      .brand img { display: block; }
      .nav-links {
        display: flex;
        gap: clamp(0.75rem, 3vw, 1.75rem);
        align-items: center;
        flex-wrap: wrap;
      }
      .nav-links a {
        color: var(--slate);
        font-weight: 550;
        font-size: 0.95rem;
      }
      .nav-links a:hover { color: var(--teal-dark); }
      .nav-links a.gh-stars {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
        font-variant-numeric: tabular-nums;
      }
      .gh-stars-num { line-height: 1; white-space: nowrap; }
      .gh-stars-logo { width: 1.2em; height: 1.2em; }
      .nav-links a.nav-discord {
        display: inline-flex;
        align-items: center;
        gap: 0.4em;
      }
      .nav-discord-logo { width: 1.15em; height: 1.15em; }

      /* ---------- BUTTONS ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1.3rem;
        border-radius: 10px;
        font-weight: 650;
        font-size: 0.98rem;
        border: 1.5px solid transparent;
        transition: transform 0.05s ease, background 0.15s ease, border-color 0.15s ease;
        white-space: nowrap;
        max-width: 100%;
      }
      .btn:active { transform: translateY(1px); }
      .btn-primary {
        background: var(--teal);
        color: #fff;
        box-shadow: 0 6px 18px -8px rgba(13, 148, 136, 0.7);
      }
      .btn-primary:hover { background: var(--teal-dark); color: #fff; }
      .btn-secondary {
        background: #fff;
        color: var(--teal-darker);
        border-color: var(--teal);
      }
      .btn-secondary:hover { background: var(--teal-tint); color: var(--teal-darker); }
      .btn-ghost {
        background: transparent;
        color: var(--slate);
        border-color: var(--line);
      }
      .btn-ghost:hover { border-color: var(--muted); color: var(--ink); }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }

      /* ---------- HERO ---------- */
      .hero {
        background:
          radial-gradient(60% 120% at 50% -10%, rgba(13, 148, 136, 0.1), transparent 60%),
          var(--bg-soft);
        border-bottom: 1px solid var(--line);
        padding: clamp(3rem, 9vw, 6rem) 0 clamp(3rem, 8vw, 5rem);
      }
      .hero-inner {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 clamp(1rem, 4vw, 2rem);
        text-align: center;
      }
      .hero-logo {
        margin: 0 auto 1.25rem;
        filter: drop-shadow(0 10px 24px rgba(13, 148, 136, 0.25));
      }
      .hero-title {
        font-size: clamp(2rem, 7vw, 3.4rem);
        line-height: 1.08;
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 0 0 0.75rem;
      }
      .hero-tagline {
        font-size: clamp(1.05rem, 3.2vw, 1.4rem);
        font-weight: 600;
        color: var(--teal-darker);
        margin: 0 auto 1rem;
        max-width: 32ch;
      }
      .hero-sub {
        color: var(--slate);
        font-size: clamp(1rem, 2.6vw, 1.12rem);
        max-width: 54ch;
        margin: 0 auto 2rem;
      }
      .hero-foot {
        margin-top: 1.5rem;
        color: var(--muted);
        font-size: 0.85rem;
        letter-spacing: 0.01em;
      }

      /* ---------- FEATURES ---------- */
      .features { padding: clamp(3rem, 8vw, 5rem) 0; }
      .features .section-title { margin-bottom: 2.5rem; }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
        gap: clamp(1rem, 3vw, 1.5rem);
      }
      .card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.5rem;
        transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
      }
      .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 34px -18px rgba(15, 23, 42, 0.25);
        border-color: #cbd5e1;
      }
      .card-icon {
        font-size: 1.9rem;
        line-height: 1;
        margin-bottom: 0.75rem;
      }
      .card h3 {
        font-size: 1.12rem;
        margin: 0 0 0.5rem;
        letter-spacing: -0.01em;
      }
      .card p { margin: 0; color: var(--slate); font-size: 0.96rem; }

      /* ---------- HOW IT WORKS ---------- */
      .how {
        background: var(--bg-soft);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: clamp(3rem, 8vw, 5rem) 0;
      }
      .steps {
        display: flex;
        align-items: stretch;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .step {
        flex: 1 1 220px;
        max-width: 280px;
        background: #fff;
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 1.5rem;
        text-align: center;
      }
      .step-num {
        width: 2.4rem;
        height: 2.4rem;
        margin: 0 auto 0.75rem;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: var(--teal);
        color: #fff;
        font-weight: 750;
        font-size: 1.1rem;
      }
      .step h3 { margin: 0 0 0.4rem; font-size: 1.15rem; }
      .step p { margin: 0; color: var(--slate); font-size: 0.95rem; }
      .step-arrow {
        align-self: center;
        font-size: 1.8rem;
        color: var(--teal);
        font-weight: 700;
      }

      /* ---------- SHOWCASE ---------- */
      .showcase { padding: clamp(3rem, 8vw, 5rem) 0; }
      .terminal {
        max-width: 720px;
        margin: 0 auto;
        background: #0b1220;
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: 0 24px 60px -28px rgba(15, 23, 42, 0.55);
        border: 1px solid #1e293b;
        text-align: left;
      }
      .terminal-compact { margin-top: 1.5rem; }
      .terminal-bar {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 0.9rem;
        background: #111a2e;
        border-bottom: 1px solid #1e293b;
      }
      .dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
      .dot-r { background: #ff5f56; }
