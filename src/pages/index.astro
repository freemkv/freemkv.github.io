      @media (prefers-reduced-motion: reduce) {
        * { scroll-behavior: auto; transition: none !important; }
        /* No cycling — show only the first phrase, "From disc to MKV." */
        .section-title--rotate .rot { animation: none; opacity: 0; }
        .section-title--rotate .rot-1 { opacity: 1; }
      }
    </style>

    <script>
      // Live GitHub star count for the nav. Fetched client-side and cached in
      // localStorage (1h TTL) to stay under the unauthenticated rate limit
      // (~60 req/hr/IP). No token. On failure, the link stays as just the star
      // icon with no number, never a broken "NaN".
      (() => {
        const el = document.querySelector('a.gh-stars');
        if (!el) return;
        const repo = el.dataset.ghRepo;
        const countEl = el.querySelector('[data-gh-stars]');
        if (!repo || !countEl) return;

        const CACHE_KEY = 'freemkv:gh-stars:' + repo;
        const TTL_MS = 60 * 60 * 1000;

        const format = (n) => {
          if (!Number.isFinite(n) || n < 0) return '';
          if (n < 1000) return String(n);
          const k = n / 1000;
          const s = k < 10 ? k.toFixed(1) : Math.round(k).toString();
          return s.replace(/\.0$/, '') + 'k';
        };

        const show = (n) => {
          const text = format(n);
          if (!text) return;
          countEl.textContent = text;
          countEl.hidden = false;
          el.setAttribute('aria-label', 'GitHub stars: ' + n.toLocaleString());
        };

        try {
          const raw = localStorage.getItem(CACHE_KEY);
          if (raw) {
            const cached = JSON.parse(raw);
            if (cached && typeof cached.count === 'number') {
              show(cached.count);
              if (Date.now() - cached.ts < TTL_MS) return;
            }
          }
        } catch {}

        fetch('https://api.github.com/repos/' + repo, {
          headers: { Accept: 'application/vnd.github+json' },
        })
          .then((r) => (r.ok ? r.json() : Promise.reject(new Error('HTTP ' + r.status))))
          .then((data) => {
            const count = data && data.stargazers_count;
            if (typeof count !== 'number') return;
            show(count);
            try {
              localStorage.setItem(CACHE_KEY, JSON.stringify({ count, ts: Date.now() }));
            } catch {}
          })
          .catch(() => {});
      })();
    </script>
  </body>
</html>
